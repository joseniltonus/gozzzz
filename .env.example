# Copie para .env e preencha (nunca commite .env — já está no .gitignore).
# No Vercel / EAS: replique as mesmas chaves EXPO_PUBLIC_* no painel de Environment Variables.

# --- Obrigatório (app e auth) — copiar do Supabase: Project Settings → API ---
# Não uses URL de exemplo; a build na Vercel embute estes valores. anon = "anon public".
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Pagamentos (checkout / assinar) ---
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...ou_pk_test_...

# --- Opcional: emails (minúsculas) que desbloqueiam o programa no cliente (QA).
# Vazio = sem lista extra além do default em código (gozzzztest@gmail.com).
# EXPO_PUBLIC_PROGRAM_ACCESS_EMAILS=gozzzztest@gmail.com,outro@dominio.com

# Legado de outros stacks (Bolt / Next): pode existir no teu .env; o app Expo usa sobretudo EXPO_PUBLIC_*.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
