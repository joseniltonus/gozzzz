{
  "expo": {
    "name": "GoZzzz - Sleep Science App",
    "slug": "gozzzz",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "gozzzz",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "description": "Transforme seu sono com ciência. Os maiores especialistas do mundo em um só app.",
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/b16c1fa5-bfaa-47b1-9a69-0343db4737ca",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gozzzz.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gozzzz.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b16c1fa5-bfaa-47b1-9a69-0343db4737ca"
      }
    },
    "owner": "josenilto",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
