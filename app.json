{
  "expo": {
    "name": "GoZzzz - Sleep Science App",
    "slug": "gozzzz",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "gozzzz",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "description": "Transforme seu sono com ciência. Os maiores especialistas do mundo em um só app.",
    "updates": {
      "enabled": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gozzzz.app"
    },
    "android": {
      "package": "com.gozzzz.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
