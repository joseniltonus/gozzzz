{
  "name": "bolt-expo-starter",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 expo start",
    "ios": "bash scripts/start-ios-simple.sh",
    "ios:clear": "bash scripts/start-ios-simple.sh --clear",
    "android": "bash scripts/start-android-with-emulator.sh",
    "android:raw": "EXPO_NO_TELEMETRY=1 expo start --android",
    "android:clear": "bash scripts/start-android-with-emulator.sh --clear",
    "start": "expo start --localhost --no-dev --clear",
    "qr": "node scripts/expo-qr.mjs",
    "build:web": "expo export --platform web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "verify:env": "node scripts/verify-env.mjs",
    "deploy:vercel": "node scripts/sync-dotenv-to-vercel.mjs",
    "eas:build:ios": "npx eas-cli build --profile production --platform ios",
    "eas:build:android": "npx eas-cli build --profile production --platform android",
    "eas:build:all": "npx eas-cli build --profile production --platform all",
    "eas:submit:ios": "npx eas-cli submit --profile production --platform ios --latest",
    "eas:submit:android": "npx eas-cli submit --profile production --platform android --latest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@lucide/lab": "^0.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "expo": "~54.0.34",
    "expo-blur": "~15.0.7",
    "expo-camera": "~17.0.8",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.8",
    "expo-haptics": "~15.0.7",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.7",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "lucide-react-native": "^0.544.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "qrcode-terminal": "^0.12.0",
    "typescript": "~5.9.2"
  }
}
